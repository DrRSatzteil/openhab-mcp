# OpenHAB connection settings
OPENHAB_URL=http://localhost:8080

# Authentication - use either API token (recommended) or username/password
OPENHAB_API_TOKEN=your_api_token_here

# Legacy authentication (not recommended)
# OPENHAB_USERNAME=your_username
# OPENHAB_PASSWORD=your_password

# MCP server settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_LEVEL=INFO

# Transport mode (streamable-http, sse, or stdio)
OPENHAB_MCP_TRANSPORT=streamable-http

# Path to openHAB log directory mounted into the container (for manage_logs read action)
# Must match the left side of the logs volume mount in docker-compose
OPENHAB_LOG_PATH=/app/logs

# Path to health analysis suppression file (set via docker-compose environment, override here if needed)
# HEALTH_SUPPRESSIONS_PATH=/app/data/health_suppressions.json

# Path to admin changelog file — audit trail of mutating tool calls (set via docker-compose environment, override here if needed)
# ADMIN_CHANGELOG_PATH=/app/data/admin_changelog.jsonl
